generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MANAGER
  VIEWER
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
  SKIPPED
}

enum DashboardFamily {
  TECHNICIANS
  INSTALLERS
  ADVISORS
  CALL_CENTER_SOURCE
  CALL_CENTER_BY_CSR
  CALL_CENTER_SUMMARY
  LEADS
  CAMPAIGNS
  TRENDING
  MARKETING
  CAPACITY
  JOB_COSTING_SUMMARY
  REVENUE_GOALS
  SALES_TODAY
  SALES_YESTERDAY
  SALES_MONTHLY_PACE
  REVENUE_MONTHLY_PACE
  BOOKING_RATE
  COMPANY_WIDE
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(VIEWER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  sessions     Session[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model RefreshSchedule {
  id        String          @id @default(cuid())
  family    DashboardFamily @unique
  cron      String
  timezone  String
  enabled   Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model JobRun {
  id            String          @id @default(cuid())
  family        DashboardFamily
  queueName     String
  jobName       String
  status        RunStatus       @default(PENDING)
  correlationId String?
  payload       Json?
  errorJson     Json?
  attempts      Int             @default(0)
  startedAt     DateTime?
  finishedAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  ingestionRuns IngestionRun[]

  @@index([family, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}

model IngestionRun {
  id                 String            @id @default(cuid())
  family             DashboardFamily
  status             RunStatus         @default(PENDING)
  requestHash        String
  idempotencyKey     String            @unique
  businessDateFrom   DateTime?
  businessDateTo     DateTime?
  requestParams      Json
  responseMeta       Json?
  errorJson          Json?
  startedAt          DateTime?
  finishedAt         DateTime?
  sourceSnapshotTime DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  rawSnapshots       RawReportSnapshot[]
  readModels         DashboardReadModel[]
  jobRunId           String?
  jobRun             JobRun?           @relation(fields: [jobRunId], references: [id], onDelete: SetNull)

  @@index([family, createdAt(sort: Desc)])
  @@index([family, businessDateFrom, businessDateTo])
  @@index([requestHash])
}

model RawReportSnapshot {
  id                 String          @id @default(cuid())
  family             DashboardFamily
  legacyTableName    String?
  tenantId           String
  category           String
  reportId           String
  requestHash        String
  businessDateFrom   DateTime?
  businessDateTo     DateTime?
  sourceSnapshotTime DateTime?
  payloadJson        Json
  fetchedAt          DateTime        @default(now())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  ingestionRunId     String?
  ingestionRun       IngestionRun?   @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)

  @@index([family, fetchedAt(sort: Desc)])
  @@index([family, sourceSnapshotTime(sort: Desc)])
  @@index([requestHash])
}

model DashboardReadModel {
  id              String          @id @default(cuid())
  family          DashboardFamily
  scopeKey        String
  businessDateFrom DateTime?
  businessDateTo   DateTime?
  payloadJson     Json
  sourceSnapshotIds Json
  snapshotTime    DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  ingestionRunId  String?
  ingestionRun    IngestionRun?   @relation(fields: [ingestionRunId], references: [id], onDelete: SetNull)

  @@unique([family, scopeKey])
  @@index([family, createdAt(sort: Desc)])
}

model GoalTrackerEntry {
  id         String   @id @default(cuid())
  year       Int
  monthIndex Int
  monthName  String
  goalAmount Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([year, monthIndex])
  @@index([year, monthIndex])
}
