  },
  "dependencies": {
    "@irbis/config": "workspace:*",
    "@irbis/db": "workspace:*",
    "@irbis/domain": "workspace:*",
    "@irbis/integrations": "workspace:*",
    "@irbis/utils": "workspace:*",
    "bullmq": "^5.41.5",
    "ioredis": "^5.4.2"
  }
}
