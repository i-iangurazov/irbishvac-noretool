{
  "name": "@irbis/worker",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/apps/worker/src/main.js",
    "start:prod": "node dist/apps/worker/src/main.js",
