# Shared
NODE_ENV=development
LOG_LEVEL=info
APP_TIMEZONE=America/Los_Angeles
ENABLE_DASHBOARD_FALLBACKS=true
WORKER_BOOTSTRAP_ON_START=false
# Matches the local docker compose services in docker-compose.yml
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/irbishvac_retool
# Optional: read-only parity source from Retool Postgres snapshots
RETOOL_DATABASE_URL=
REDIS_URL=redis://localhost:6379
# Upstash example:
# REDIS_URL=rediss://default:<password>@hardy-jay-81595.upstash.io:6379
SENTRY_DSN=

# Auth
AUTH_COOKIE_SECRET=replace-me
AUTH_DEFAULT_ADMIN_EMAIL=admin@example.com
AUTH_DEFAULT_ADMIN_PASSWORD=ChangeMe123!

# Web
NEXT_PUBLIC_APP_NAME=IRBIS HVAC Dashboards
# Server-only upstream API used by the Next.js proxy routes.
API_BASE_URL=http://localhost:3001
# Optional browser-visible override. Usually not needed on Vercel.
NEXT_PUBLIC_API_BASE_URL=

# ServiceTitan
SERVICETITAN_CLIENT_ID=
SERVICETITAN_CLIENT_SECRET=
SERVICETITAN_APP_KEY=
SERVICETITAN_TENANT_ID=686965608

# ServiceTitan report ids
ST_REPORT_TECHNICIANS=66109112
ST_REPORT_INSTALLERS=112224016
ST_REPORT_ADVISORS=80249474
ST_REPORT_CALL_CENTER_SOURCE=6771127
ST_REPORT_CALL_CENTER_PERFORMANCE=116192131
ST_REPORT_LEADS=219
ST_REPORT_CAMPAIGNS=898
ST_REPORT_BOOKING_RATE=930
ST_REPORT_TRENDING=115808515
ST_REPORT_SALES=228
ST_REPORT_REVENUE_MONTHLY_PACE=111413515
ST_REPORT_CAPACITY_CATEGORY=business-unit-dashboard
ST_REPORT_CAPACITY_ID=111298433
ST_REPORT_JOB_COSTING_CATEGORY=operations
ST_REPORT_JOB_COSTING_ID=27381966
ST_REPORT_REVENUE_GOALS_CATEGORY=business-unit-dashboard
ST_REPORT_REVENUE_GOALS_ID=216

# Default business-unit groups
ST_BU_INSTALLERS=1809,64313020
ST_BU_ADVISORS=1812,64326403,64567559
ST_BU_COMPANY=1809,1810,1812,64313020,64315277,64326403,64567559,64569092,64569731

# Optional public Cloudflare R2 asset host
R2_PUBLIC_BASE_URL=
R2_TECHNICIAN_PHOTO_EXT=png
R2_TECHNICIAN_PHOTO_NAME_STYLE=space
R2_LOGO_KEY=irbis-logo_new_cmyk.png

# Retool storage asset folders to preserve current matching semantics
ASSET_FOLDER_TECHNICIAN_PHOTOS=technicians_photos
ASSET_FOLDER_LOGOS=
